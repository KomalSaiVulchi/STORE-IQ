# ============================================================
# Purplle StoreIQ — Environment Configuration
# Copy this to .env and update values for your environment
# ============================================================

# --- Core ---
APP_NAME=storeiq-api
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+psycopg2://storeiq:storeiq@postgres:5432/storeiq
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
POSTGRES_DB=storeiq
POSTGRES_USER=storeiq
POSTGRES_PASSWORD=storeiq

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_RAW_TOPIC=raw_events
KAFKA_SESSIONS_TOPIC=sessions
KAFKA_ANOMALIES_TOPIC=anomalies

# --- Store Configuration ---
STORE_TIMEZONE=Asia/Kolkata
STORE_CAPACITY=120
STALE_FEED_MINUTES=10

# --- Security ---
# Set a strong API key for production. Leave empty to disable auth.
API_KEY=
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
# Max API requests per minute per client IP
RATE_LIMIT_PER_MINUTE=120

# --- Pipeline ---
FRAME_SKIP=3
UVICORN_WORKERS=2
USE_MOCK_DETECTION=false
# Multi-camera: CAMERA_SOURCES="CAM_ENTRY_01=/app/dataset/CCTV Footage/CAM 1.mp4,CAM_FLOOR_02=/app/dataset/CCTV Footage/CAM 2.mp4"
CAMERA_SOURCES=
VIDEO_SOURCE=./pipeline/sample_video.mp4
STORE_ID=STORE_BLR_002

# --- ReID ---
REID_SIMILARITY_THRESHOLD=0.75
REID_MAX_GAP_SECONDS=3600
REID_TTL_SECONDS=3600
# Optional override — defaults loaded from pipeline/store_layout.json
ADJACENT_CAMERAS_JSON=

# --- Zone Configuration ---
ZONE_CONFIG_PATH=./pipeline/zone_config.json
SAMPLE_VIDEO_PATH=./pipeline/sample_video.mp4
USE_MOCK_DETECTION=false
